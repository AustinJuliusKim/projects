# E2B API key — provisions the per-session sandboxes (YOUR infra cost, separate
# from user token cost). Get one at https://e2b.dev
E2B_API_KEY=

# Port the WebSocket server listens on.
PORT=8787

# Kill a session's sandbox after this many ms of inactivity.
IDLE_TIMEOUT_MS=300000

# Hard cap on total tokens per session (stops runaway agent loops, even under BYOK).
SESSION_TOKEN_CAP=2000000

# E2B template id with Claude Code preinstalled (built from sandbox-template/).
# Falls back to a base template + runtime install if unset (slower cold start).
E2B_TEMPLATE=

# pino log level
LOG_LEVEL=info
