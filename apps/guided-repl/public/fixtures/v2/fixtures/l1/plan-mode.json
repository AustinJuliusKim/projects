radient(rgba(14,14,14,0.55), rgba(14,14,14,0.8)),\n      linear-gradient(135deg, #2c3a47 0%, #4a6274 40%, #8c6f4e 100%);\n  }\n\n  .hero h1 {\n    font-size: clamp(2.2rem, 6vw, 4rem);\n    font-weight: normal;\n    letter-spacing: 0.06em;\n  }\n\n  .hero p {\n    margin-top: 1rem;\n    color: var(--muted);\n    font-family: Helvetica, Arial, sans-serif;\n    font-size: 0.95rem;\n    letter-spacing: 0.08em;\n  }\n\n  .hero a.cta {\n    display: inline-block;\n    margin-top: 2.5rem;\n    padding: 0.75rem 2rem;\n    border: 1px solid var(--accent);\n    color: var(--accent);\n    font-family: Helvetica, Arial, sans-serif;\n    font-size: 0.8rem;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    transition: background 0.2s, color 0.2s;\n  }\n\n  .hero a.cta:hover {\n    background: var(--accent);\n    color: var(--bg);\n  }\n\n  /* ---------- Sections ---------- */\n  section {\n    max-width: var(--max-width);\n    margin: 0 auto;\n    padding: 5rem 1.5rem;\n  }\n\n  h2 {\n    font-weight: normal;\n    font-size: 1.6rem;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    margin-bottom: 2.5rem;\n    text-align: center;\n  }\n\n  h2::after {\n    content: \"\";\n    display: block;\n    width: 3rem;\n    height: 1px;\n    background: var(--accent);\n    margin: 0.9rem auto 0;\n  }\n\n  /* ---------- Gallery ---------- */\n  .gallery {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n    gap: 1rem;\n  }\n\n  .gallery figure {\n    position: relative;\n    aspect-ratio: 4 / 3;\n    overflow: hidden;\n    background: var(--surface);\n  }\n\n  /* When you add real photos, drop an <img> inside each <figure>:\n     <img src=\"photos/one.jpg\" alt=\"...\"> — the rule below handles it. */\n  .gallery img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    transition: transform 0.4s ease;\n  }\n\n  .gallery figure:hover img {\n    transform: scale(1.04);\n  }\n\n  .placeholder {\n    width: 100%;\n    height: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: rgba(255, 255, 255, 0.5);\n    font-family: Helvetica, Arial, sans-serif;\n    font-size: 0.75rem;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    transition: transform 0.4s ease;\n  }\n\n  .gallery figure:hover .placeholder {\n    transform: scale(1.04);\n  }\n\n  .p1 { background: linear-gradient(160deg, #3b4d5c, #1f2a33); }\n  .p2 { background: linear-gradient(160deg, #6e5a43, #2e2418); }\n  .p3 { background: linear-gradient(160deg, #4d5c4a, #1e2620); }\n  .p4 { background: linear-gradient(160deg, #5c4a55, #241b22); }\n  .p5 { background: linear-gradient(160deg, #435c6e, #16222b); }\n  .p6 { background: linear-gradient(160deg, #6e4343, #2b1616); }\n\n  .gallery figcaption {\n    position: absolute;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    padding: 0.6rem 0.9rem;\n    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));\n    font-family: Helvetica, Arial, sans-serif;\n    font-size: 0.75rem;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: var(--text);\n    opacity: 0;\n    transition: opacity 0.3s;\n  }\n\n  .gallery figure:hover figcaption {\n    opacity: 1;\n  }\n\n  /* ---------- About ---------- */\n  .about-inner {\n    max-width: 640px;\n    margin: 0 auto;\n    text-align: center;\n    color: var(--muted);\n    font-size: 1.05rem;\n  }\n\n  /* ---------- Contact ---------- */\n  .contact {\n    text-align: center;\n  }\n\n  .contact a.email {\n    display: inline-block;\n    margin-top: 0.5rem;\n    font-size: 1.3rem;\n    color: var(--accent);\n    border-bottom: 1px solid transparent;\n    transition: border-color 0.2s;\n  }\n\n  .contact a.email:hover {\n    border-color: var(--accent);\n  }\n\n  .socials {\n    margin-top: 1.5rem;\n    display: flex;\n    justify-content: center;\n    gap: 1.5rem;\n    font-family: Helvetica, Arial, sans-serif;\n    font-size: 0.8rem;