# Lambda Function URL (from `sam deploy` output ApiUrl)
VITE_API_URL=https://xxxxxxxx.lambda-url.us-east-1.on.aws/

# VAPID public key (from `sam deploy` output VapidPublicKey)
VITE_VAPID_PUBLIC_KEY=

# Tip-the-dev links (optional — tip UI is hidden when unset).
# Venmo profile URL and a Stripe pay-what-you-want Payment Link.
VITE_TIP_VENMO_URL=
VITE_TIP_STRIPE_URL=
